# Hermes Agent lean config example
# Copy to ~/.hermes/config.yaml and edit. Keep API keys in ~/.hermes/.env.

model:
  provider: openai
  name: gpt-5.1
  # base_url: ""   # Optional OpenAI-compatible endpoint.

agent:
  max_iterations: 90
  quiet_mode: false
  save_trajectories: false
  compression:
    enabled: true

# Lean default tool surface: files, local terminal/process, web research,
# skills, memory, session_search, todo, and clarify.
tools:
  enabled_toolsets:
    - file
    - terminal
    - web
    - skills
    - memory
    - session_search
    - todo
    - clarify
  disabled_toolsets: []

terminal:
  backend: local
  cwd: ""
  approvals:
    enabled: true
    mode: ask
  background_processes:
    notify_on_complete: true

web:
  # auto chooses an available configured backend from your .env keys.
  backend: auto
  max_results: 5

memory:
  enabled: true
  provider: local

skills:
  enabled: true
  auto_sync: true

session_search:
  enabled: true

telegram:
  enabled: true
  # Secrets live in .env: TELEGRAM_BOT_TOKEN, TELEGRAM_ALLOWED_USERS,
  # TELEGRAM_HOME_CHAT_ID.
  parse_mode: markdown
  typing_indicator: true

gateway:
  platform: telegram
  delivery:
    split_long_messages: true

approvals:
  dangerous_commands: ask
  file_writes: ask

security:
  redact_secrets: true
  yolo_mode: false

logging:
  level: INFO
  logs_dir: ""

display:
  skin: default
  tool_progress: true
