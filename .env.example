# Hermes Agent lean environment example
# Copy to ~/.hermes/.env (or export in your shell) and fill only the keys you use.
# Non-secret behavior belongs in ~/.hermes/config.yaml, not here.

# --- Model provider credentials ---
# Pick one or more providers. Configure the active provider/model in config.yaml
# or with `hermes model` / `hermes config set`.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
XAI_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=

# --- Telegram gateway ---
# Required only when running `hermes gateway` for Telegram.
TELEGRAM_BOT_TOKEN=
# Optional: comma-separated numeric user IDs allowed to talk to the bot.
TELEGRAM_ALLOWED_USERS=
# Optional: default chat/channel for notifications.
TELEGRAM_HOME_CHAT_ID=

# --- Web research backends ---
# Configure web.backend in config.yaml when you want a specific backend.
TAVILY_API_KEY=
EXA_API_KEY=
FIRECRAWL_API_KEY=
BRAVE_API_KEY=
SERPAPI_API_KEY=
PARALLEL_API_KEY=

# --- Optional service integrations kept in the lean fork ---
# External secret manager support.
BITWARDEN_ACCESS_TOKEN=
# Local/remote MCP servers may define their own secret env vars.
